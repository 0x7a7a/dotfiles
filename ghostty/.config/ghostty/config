#font
font-family = Hack
font-size = 13
font-thicken = true
font-thicken-strength = 0

#ui
background-opacity = 0.95

# option
macos-option-as-alt = true
macos-titlebar-style = tabs 

#keybind
keybind = super+t=new_tab
keybind = super+enter=new_split:down
keybind = super+shift+enter=new_split:right
